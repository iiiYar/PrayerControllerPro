<Window x:Class="PrayerControllerPro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:state="clr-namespace:PrayerControllerPro.App.State"
        xmlns:converters="clr-namespace:PrayerControllerPro.App.Converters"
        mc:Ignorable="d"
        Title="Prayer Controller Pro"
        Width="460"
        Height="860"
        MinWidth="460"
        MinHeight="800"
        Background="{StaticResource Brush.WindowBackground}"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.WindowBackground}">
        <Grid Visibility="{Binding IsWidgetMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="12,12,12,8"
                    Padding="0,0,0,10"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Prayer Controller Pro"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTimeText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       VerticalAlignment="Center"/>
                            <Border Margin="10,0"
                                    Width="1"
                                    Height="14"
                                    Background="{StaticResource Brush.Border}"/>
                            <TextBlock Text="{Binding CurrentDateText}"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,12,0,0"
                            Padding="3"
                            Background="{StaticResource Brush.Surface}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <UniformGrid Columns="6">
                            <Button x:Name="WidgetModeButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="{Binding WidgetButtonText}"/>
                            <Button x:Name="AddReminderButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Reminder"/>
                            <Button x:Name="SettingsButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="Settings"/>
                            <Button x:Name="AboutButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="About"/>
                            <Button x:Name="LogsButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="Logs"/>
                            <Button x:Name="ExitButton"
                                    Margin="2,0"
                                    Padding="5,6"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="Exit"/>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="12,0,12,8"
                    Padding="16"
                    Style="{StaticResource SurfaceBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding CountdownPrayerName}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TimingAccent}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding CountdownLabel}"
                                       Foreground="{StaticResource Brush.TextSecondary}"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="10,5"
                                Background="{StaticResource Brush.WindowBackground}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding CountdownTargetText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TimingAccent}"/>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,20,0,0"
                               Text="{Binding CountdownValue}"
                               FontSize="52"
                               FontWeight="Bold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding CountdownMetaText}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextWrapping="Wrap"/>

                    <Border Margin="0,16,0,0"
                            Padding="10,8"
                            Background="{StaticResource Brush.WindowBackground}"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Status"
                                       Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding StatusText}"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="12,0,12,8"
                    Padding="12,10"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Source" Style="{StaticResource SectionLabelStyle}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding SourceText}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Method" Style="{StaticResource SectionLabelStyle}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding MethodText}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Text="Location" Style="{StaticResource SectionLabelStyle}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding CityText}"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="12,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Today&apos;s Prayer Times"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            x:Name="RefreshButton"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Refresh"/>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="{StaticResource Brush.Surface}">
                        <ItemsControl ItemsSource="{Binding Prayers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type state:PrayerCardState}">
                                    <Grid Margin="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="AccentBar" Grid.Column="0" Background="Transparent"/>
                                        <Border x:Name="RowSurface"
                                                Grid.Column="1"
                                                Padding="14,13"
                                                Background="{StaticResource Brush.WindowBackground}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Width="132">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.TextPrimary}"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding RuleSummary}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource Brush.TextSecondary}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Adhan"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding TimeText}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.TextPrimary}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" Margin="18,0,0,0">
                                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Iqama"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               Text="{Binding IqamaText}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.TimingAccent}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" Margin="18,0,0,0" HorizontalAlignment="Right">
                                                    <Border x:Name="AutomationBadge"
                                                            Padding="10,4"
                                                            Background="{StaticResource Brush.SurfaceAlt}"
                                                            CornerRadius="6"
                                                            HorizontalAlignment="Right">
                                                        <TextBlock x:Name="AutomationBadgeText"
                                                                   Text="Auto"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                                                    </Border>

                                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button x:Name="EditPrayerButton"
                                                                Tag="{Binding Id}"
                                                                Margin="0,0,6,0"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Content="..."/>
                                                        <Button x:Name="DeleteReminderButton"
                                                                Tag="{Binding Id}"
                                                                Style="{StaticResource IconButtonStyle}"
                                                                Content="X"
                                                                Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsNext}" Value="True">
                                            <Setter TargetName="RowSurface" Property="Background" Value="{StaticResource Brush.Surface}"/>
                                            <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource Brush.TimingAccent}"/>
                                            <Setter TargetName="AutomationBadge" Property="Background" Value="{StaticResource Brush.TimingAccent}"/>
                                            <Setter TargetName="AutomationBadgeText" Property="Text" Value="Up Next"/>
                                            <Setter TargetName="AutomationBadgeText" Property="Foreground" Value="{StaticResource Brush.WindowBackground}"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="RowSurface" Property="Background" Value="{StaticResource Brush.Surface}"/>
                                            <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource Brush.PrimaryAccent}"/>
                                            <Setter TargetName="AutomationBadge" Property="Background" Value="{StaticResource Brush.PrimaryAccent}"/>
                                            <Setter TargetName="AutomationBadgeText" Property="Text" Value="Active"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter TargetName="AutomationBadge" Property="Background" Value="{StaticResource Brush.WarningAccent}"/>
                                            <Setter TargetName="AutomationBadgeText" Property="Text" Value="Off"/>
                                            <Setter TargetName="AutomationBadgeText" Property="Foreground" Value="{StaticResource Brush.WindowBackground}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Border Visibility="{Binding IsWidgetMode, Converter={StaticResource BoolToVisibilityConverter}}"
                Margin="8"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid x:Name="WidgetHeader"
                  MouseLeftButtonDown="WidgetHeader_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource Brush.TimingAccent}"
                        CornerRadius="10,0,0,10"/>

                <Grid Grid.Column="1" Margin="12,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="PRAYER WIDGET"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextSecondary}"/>
                            <Border Margin="8,0"
                                    Width="1"
                                    Height="12"
                                    Background="{StaticResource Brush.Border}"/>
                            <TextBlock Text="{Binding CountdownTargetText}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TimingAccent}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="CompactDashboardButton"
                                    Width="48"
                                    Height="28"
                                    Margin="0,0,5,0"
                                    Padding="6,4"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="Open"/>
                            <Button x:Name="CompactExitButton"
                                    Width="32"
                                    Height="28"
                                    Padding="6,4"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="X"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CountdownPrayerName}"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Margin="0,3,0,0"
                                       Text="{Binding CountdownLabel}"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding CountdownValue}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="2"
                            Padding="9,7"
                            Background="{StaticResource Brush.WindowBackground}"
                            CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="{Binding CurrentTimeText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TimingAccent}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
