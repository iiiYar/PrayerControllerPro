<Window x:Class="PrayerControllerPro.App.Dialogs.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Settings"
        Height="640"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DialogSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelStyle}">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ReadableFieldTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="BorderBrush" Value="#C9D1D9"/>
        </Style>

        <Style x:Key="ReadableFieldComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#DDE6F0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CFE5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadableFieldComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#C9D1D9"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ReadableFieldComboBoxItemStyle}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="App settings"
                           Style="{StaticResource DialogTitleStyle}"/>
                <TextBlock Margin="0,8,0,24"
                           Text="Choose the city, calculation method, startup behavior, notifications, and audio files for adhan and iqama."
                           Style="{StaticResource DialogBodyStyle}"/>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Location and schedule"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Select the city and prayer time method used by the dashboard and widget."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <TextBlock Text="City"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="CityComboBox"
                                  Margin="0,0,0,16"
                                  Style="{StaticResource ReadableFieldComboBoxStyle}"
                                  DisplayMemberPath="DisplayName"/>

                        <TextBlock Margin="0,-8,0,16"
                                   Style="{StaticResource DialogBodyStyle}">
                            <Run Text="Selected city: "/>
                            <Run Text="{Binding ElementName=CityComboBox, Path=SelectedItem.DisplayName}"
                                 Foreground="{StaticResource Brush.TextPrimary}"/>
                            <Run Text=", "/>
                            <Run Text="{Binding ElementName=CityComboBox, Path=SelectedItem.ApiCountry}"
                                 Foreground="{StaticResource Brush.TextPrimary}"/>
                        </TextBlock>

                        <TextBlock x:Name="DistrictLabel"
                                   Text="District"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="DistrictComboBox"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource ReadableFieldComboBoxStyle}"
                                  DisplayMemberPath="DisplayName"/>
                        <TextBlock x:Name="DistrictHelpTextBlock"
                                   Margin="0,0,0,16"
                                   Text="Optional. Choose Use city center to keep the current city-level timing."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <TextBlock Text="Calculation method"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="MethodComboBox"
                                  Style="{StaticResource ReadableFieldComboBoxStyle}"
                                  DisplayMemberPath="DisplayName"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="App behavior"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Control startup behavior and shared playback volume."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <CheckBox x:Name="AutoStartCheckBox"
                                  Margin="0,0,0,16"
                                  Content="Start app with Windows"/>

                        <CheckBox x:Name="AutoUpdateCheckBox"
                                  Margin="0,0,0,16"
                                  Content="Check for updates automatically"/>

                        <TextBlock Text="Media control method"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="MediaControlModeComboBox"
                                  Margin="0,0,0,8"
                                  Style="{StaticResource ReadableFieldComboBoxStyle}"
                                  DisplayMemberPath="DisplayName"/>
                        <TextBlock Margin="0,0,0,16"
                                   Text="Choose the current Play/Pause key method, or lower other app volumes during prayer without pressing Play/Pause."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <Border x:Name="VolumeGuardSettingsPanel"
                                Margin="0,0,0,16"
                                Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Volume guard level"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <ComboBox x:Name="VolumeGuardLevelComboBox"
                                          Margin="0,0,0,12"
                                          Style="{StaticResource ReadableFieldComboBoxStyle}"
                                          DisplayMemberPath="DisplayName"/>

                                <TextBlock Text="Fade style"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <ComboBox x:Name="VolumeGuardTransitionModeComboBox"
                                          Margin="0,0,0,12"
                                          Style="{StaticResource ReadableFieldComboBoxStyle}"
                                          DisplayMemberPath="DisplayName"/>

                                <TextBlock Text="Custom level (%)"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBox x:Name="CustomVolumeGuardTextBox"
                                         Margin="0,0,0,10"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"
                                         Height="36"/>
                                <TextBlock Text="0 means silent. Engineers can enter any value from 0 to 100."
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Audio volume"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="VolumeSlider"
                                    Minimum="0"
                                    Maximum="1"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource DialogBodyStyle}"
                                       Text="{Binding ElementName=VolumeSlider, Path=Value, StringFormat={}{0:P0}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Notifications"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Choose where notifications go, then choose which app events are allowed to notify you."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <Border Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Notification channels"
                                           Style="{StaticResource DialogLabelStyle}"/>

                                <CheckBox x:Name="EnableWindowsNotificationsCheckBox"
                                          Margin="0,0,0,12"
                                          Content="Windows tray notifications"/>

                                <CheckBox x:Name="EnableDiscordNotificationsCheckBox"
                                          Margin="0,0,0,12"
                                          Content="Discord webhook notifications"/>

                                <TextBlock Text="Discord webhook URL"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBox x:Name="DiscordWebhookTextBox"
                                         Margin="0,0,0,12"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"
                                         Height="36"/>

                                <Button x:Name="TestDiscordButton"
                                        Width="132"
                                        Height="36"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Test Discord"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Events that can notify"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox x:Name="NotifyScheduleCheckBox"
                                              Margin="0,0,0,10"
                                              Content="Schedule refresh"/>
                                    <CheckBox x:Name="NotifyMediaCheckBox"
                                              Grid.Column="2"
                                              Margin="0,0,0,10"
                                              Content="Media pause/resume"/>
                                    <CheckBox x:Name="NotifyAudioCheckBox"
                                              Grid.Row="1"
                                              Content="Adhan and iqama"/>
                                    <CheckBox x:Name="NotifyAppCheckBox"
                                              Grid.Row="1"
                                              Grid.Column="2"
                                              Content="App lifecycle"/>
                                </Grid>

                                <TextBlock Margin="0,12,0,0"
                                           Text="Tip: logs are always written even if notifications are disabled."
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Adhan audio"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Optional audio that plays as soon as the prayer time starts."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <CheckBox x:Name="EnableAdhanAudioCheckBox"
                                  Margin="0,0,0,16"
                                  Content="Play adhan when prayer time starts"/>

                        <TextBlock Text="Audio file"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="AdhanPathTextBox"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ReadableFieldTextBoxStyle}"
                                 Height="36"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BrowseAdhanButton"
                                    Width="108"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse"/>
                            <Button x:Name="TestAdhanButton"
                                    Width="96"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Test"/>
                            <Button x:Name="StopAdhanButton"
                                    Width="96"
                                    Height="36"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Stop"/>
                        </StackPanel>

                        <Border Margin="0,16,0,0"
                                Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Download preset"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBlock Margin="0,0,0,12"
                                           Text="Paste a licensed adhan audio URL. The app downloads it once and stores it locally for offline playback."
                                           Style="{StaticResource DialogBodyStyle}"/>
                                <TextBox x:Name="AdhanPresetUrlTextBox"
                                         Margin="0,0,0,12"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"
                                         Height="36"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="DownloadAdhanPresetButton"
                                            Width="112"
                                            Height="36"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Download"/>
                                    <Button x:Name="ClearAdhanPresetButton"
                                            Width="112"
                                            Height="36"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Clear cache"/>
                                </StackPanel>
                                <TextBlock x:Name="AdhanPresetStatusTextBlock"
                                           Margin="0,10,0,0"
                                           Text="No preset downloaded yet."
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Iqama audio"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Optional audio that plays at the configured iqama time."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <CheckBox x:Name="EnableIqamaAudioCheckBox"
                                  Margin="0,0,0,16"
                                  Content="Play iqama at iqama time"/>

                        <TextBlock Text="Audio file"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="IqamaPathTextBox"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource ReadableFieldTextBoxStyle}"
                                 Height="36"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BrowseIqamaButton"
                                    Width="108"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse"/>
                            <Button x:Name="TestIqamaButton"
                                    Width="96"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Test"/>
                            <Button x:Name="StopIqamaButton"
                                    Width="96"
                                    Height="36"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Stop"/>
                        </StackPanel>

                        <Border Margin="0,16,0,0"
                                Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="Download preset"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBlock Margin="0,0,0,12"
                                           Text="Paste a licensed iqama audio URL. Downloaded presets are cached locally and reused offline."
                                           Style="{StaticResource DialogBodyStyle}"/>
                                <TextBox x:Name="IqamaPresetUrlTextBox"
                                         Margin="0,0,0,12"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"
                                         Height="36"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="DownloadIqamaPresetButton"
                                            Width="112"
                                            Height="36"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Content="Download"/>
                                    <Button x:Name="ClearIqamaPresetButton"
                                            Width="112"
                                            Height="36"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="Clear cache"/>
                                </StackPanel>
                                <TextBlock x:Name="IqamaPresetStatusTextBlock"
                                           Margin="0,10,0,0"
                                           Text="No preset downloaded yet."
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Width="110"
                    Height="40"
                    Margin="0,0,12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Cancel"/>
            <Button x:Name="SaveButton"
                    Width="110"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Save"/>
        </StackPanel>
    </Grid>
</Window>
