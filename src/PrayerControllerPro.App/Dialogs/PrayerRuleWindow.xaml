<Window x:Class="PrayerControllerPro.App.Dialogs.PrayerRuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prayer Automation"
        Height="520"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DialogSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelStyle}">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           Style="{StaticResource DialogTitleStyle}"/>
                <TextBlock Margin="0,8,0,24"
                       Text="Adjust pause, resume, adhan, and iqama behavior for this prayer."
                           Style="{StaticResource DialogBodyStyle}"/>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Automation"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Enable or disable automatic media handling for this prayer."
                                   Style="{StaticResource DialogBodyStyle}"/>
                        <CheckBox x:Name="EnabledCheckBox"
                                  Content="Enable automatic pause and resume"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Timing offsets"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Set the minute offsets used around the prayer and iqama."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <TextBlock Text="Pause media before prayer (minutes)"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="StopBeforeTextBox"
                                 Margin="0,0,0,16"
                                 Height="36"/>

                        <TextBlock Text="Resume media after prayer (minutes)"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="ResumeAfterTextBox"
                                 Margin="0,0,0,16"
                                 Height="36"/>

                        <TextBlock Text="Iqama offset after adhan (minutes)"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="IqamaOffsetTextBox"
                                 Height="36"/>
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Audio notifications"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Choose whether adhan and iqama audio should play for this prayer."
                                   Style="{StaticResource DialogBodyStyle}"/>
                        <CheckBox x:Name="PlayAdhanCheckBox"
                                  Margin="0,0,0,12"
                                  Content="Play adhan at prayer time"/>
                        <CheckBox x:Name="PlayIqamaCheckBox"
                                  Content="Play iqama"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Width="110"
                    Height="40"
                    Margin="0,0,12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Cancel"/>
            <Button x:Name="SaveButton"
                    Width="110"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Save"/>
        </StackPanel>
    </Grid>
</Window>
