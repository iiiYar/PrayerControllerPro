<Window x:Class="PrayerControllerPro.App.Dialogs.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logs"
        Icon="../Assets/app.ico"
        Width="760"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brush.WindowBackground}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="Segoe UI Variable Text">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Application logs"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>
                <TextBlock Margin="0,6,0,0"
                           Text="Recent app activity, scheduler actions, notifications, settings changes, and failures."
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="RefreshButton"
                    Width="96"
                    Height="36"
                    Margin="12,0,0,0"
                    VerticalAlignment="Top"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Refresh"/>
            <Button Grid.Column="2"
                    x:Name="OpenFolderButton"
                    Width="112"
                    Height="36"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Open folder"/>
            <Button Grid.Column="3"
                    x:Name="ClearButton"
                    Width="96"
                    Height="36"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Clear"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,16,0,12"
                Padding="12,9"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock x:Name="LogFolderTextBlock"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Time" Style="{StaticResource SectionLabelStyle}"/>
            <TextBlock Grid.Column="1" Text="Level" Style="{StaticResource SectionLabelStyle}"/>
            <TextBlock Grid.Column="2" Text="Area" Style="{StaticResource SectionLabelStyle}"/>
            <TextBlock Grid.Column="3" Text="Message" Style="{StaticResource SectionLabelStyle}"/>
        </Grid>

        <TextBox Grid.Row="3"
                 x:Name="LogTextBox"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="{StaticResource Brush.SurfaceAlt}"
                 Foreground="{StaticResource Brush.TextPrimary}"
                 BorderBrush="{StaticResource Brush.Border}"
                 BorderThickness="1"
                 Padding="12"/>
    </Grid>
</Window>
