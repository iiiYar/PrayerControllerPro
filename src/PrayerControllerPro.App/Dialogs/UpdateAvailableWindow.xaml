<Window x:Class="PrayerControllerPro.App.Dialogs.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Width="520"
        Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="Segoe UI Variable Text">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TitleTextBlock"
                       Text="Update available"
                       FontFamily="Segoe UI Variable Display"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock x:Name="VersionTextBlock"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Padding="14"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Release notes"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBox x:Name="NotesTextBox"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource Brush.SurfaceAlt}"
                         Foreground="{StaticResource Brush.TextPrimary}"
                         BorderBrush="{StaticResource Brush.Border}"
                         BorderThickness="1"
                         Padding="10"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="MandatoryTextBlock"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.WarningAccent}"
                       FontWeight="SemiBold"/>

            <Button Grid.Column="1"
                    x:Name="SkipButton"
                    Width="98"
                    Height="38"
                    Margin="8,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Skip"/>
            <Button Grid.Column="2"
                    x:Name="LaterButton"
                    Width="98"
                    Height="38"
                    Margin="8,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Later"/>
            <Button Grid.Column="3"
                    x:Name="ReleaseNotesButton"
                    Width="112"
                    Height="38"
                    Margin="8,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Release notes"/>
            <Button Grid.Column="4"
                    x:Name="DownloadButton"
                    Width="106"
                    Height="38"
                    Margin="8,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Download"/>
        </Grid>
    </Grid>
</Window>
