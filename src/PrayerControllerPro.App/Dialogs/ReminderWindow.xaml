<Window x:Class="PrayerControllerPro.App.Dialogs.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Reminder"
        Icon="../Assets/app.ico"
        Height="620"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.WindowBackground}"
        Foreground="{StaticResource Brush.TextPrimary}"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DialogSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="DialogLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelStyle}">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ReadableFieldTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="BorderBrush" Value="#C9D1D9"/>
        </Style>

        <Style x:Key="ReadableFieldComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#DDE6F0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CFE5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReadableFieldComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#C9D1D9"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ReadableFieldComboBoxItemStyle}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           Style="{StaticResource DialogTitleStyle}"/>
                <TextBlock Margin="0,8,0,22"
                           Text="Create a custom schedule item with a clear name, 12-hour time, and prayer-style media timing."
                           Style="{StaticResource DialogBodyStyle}"/>

                <Border Margin="0,0,0,16"
                        Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Reminder details"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="This name appears in today's schedule next to the built-in prayers."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <TextBlock Text="Name"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="NameTextBox"
                                 Margin="0,0,0,18"
                                 Height="38"
                                 Style="{StaticResource ReadableFieldTextBoxStyle}"/>

                        <TextBlock Text="Time"
                                   Style="{StaticResource DialogLabelStyle}"/>
                        <Border Padding="12"
                                Background="{StaticResource Brush.SurfaceAlt}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Radius.Small}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Hour"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBlock Grid.Column="2"
                                           Text="Minute"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBlock Grid.Column="4"
                                           Text="AM / PM"
                                           Style="{StaticResource DialogLabelStyle}"/>

                                <ComboBox x:Name="HourComboBox"
                                          Grid.Row="1"
                                          Height="38"
                                          Style="{StaticResource ReadableFieldComboBoxStyle}"
                                          HorizontalContentAlignment="Center"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           Text=":"/>
                                <ComboBox x:Name="MinuteComboBox"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          Height="38"
                                          Style="{StaticResource ReadableFieldComboBoxStyle}"
                                          HorizontalContentAlignment="Center"/>
                                <ComboBox x:Name="PeriodComboBox"
                                          Grid.Row="1"
                                          Grid.Column="4"
                                          Height="38"
                                          Style="{StaticResource ReadableFieldComboBoxStyle}"
                                          HorizontalContentAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        Style="{StaticResource SurfaceBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Timing controls"
                                   Style="{StaticResource DialogSectionTitleStyle}"/>
                        <TextBlock Margin="0,6,0,16"
                                   Text="Custom reminders can pause media before the reminder time and resume it after, just like a custom prayer entry."
                                   Style="{StaticResource DialogBodyStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Pause before"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBox x:Name="PauseBeforeTextBox"
                                         Height="38"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="Minutes before time"
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Resume after"
                                           Style="{StaticResource DialogLabelStyle}"/>
                                <TextBox x:Name="ResumeAfterTextBox"
                                         Height="38"
                                         Style="{StaticResource ReadableFieldTextBoxStyle}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Text="Minutes after time"
                                           Style="{StaticResource DialogBodyStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,16,0,0"
                                Padding="12"
                                Background="{StaticResource Brush.WindowBackground}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Text="Example: a reminder at 08:15 PM with Pause before 5 and Resume after 10 will pause media at 08:10 PM and resume at 08:25 PM."
                                       Style="{StaticResource DialogBodyStyle}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0,20,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Width="110"
                    Height="40"
                    Margin="0,0,12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Cancel"/>
            <Button x:Name="SaveButton"
                    Width="110"
                    Height="40"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Save"/>
        </StackPanel>
    </Grid>
</Window>
